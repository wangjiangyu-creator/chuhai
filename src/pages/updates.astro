---
import Layout from '../components/Layout.astro';
import SourceBadge from '../components/SourceBadge.astro';
import updates from '../data/updates.json';
import risks from '../data/risks.json';
import { formatDate, riskLabel, text } from '../lib/i18n';

const lang = 'zh';
---

<Layout title="最新发展 | 中国企业出海" description="中国企业出海相关法规、执法和案例动态时间线。" lang={lang} route="updates">
  <section class="page-head">
    <SourceBadge lang={lang} />
    <h1>最新发展</h1>
    <p>本时间线关注会改变企业准备窗口的规则和执法变化。静态站不自动抓取新闻；后续通过数据文件人工更新。</p>
  </section>
  <section class="section">
    <div class="timeline">
      {updates.map((item) => (
        <article class="timeline-item">
          <div class="timeline-meta">
            <span>{formatDate(item.date, lang)}</span>
            <span>{item.jurisdiction}</span>
            {item.effectiveDate && <span>生效/适用：{formatDate(item.effectiveDate, lang)}</span>}
          </div>
          <h2>{text(item.title, lang)}</h2>
          <p>{text(item.summary, lang)}</p>
          <div class="tag-list">
            {item.riskTypes.map((risk) => <span>{riskLabel(risk, lang, risks)}</span>)}
          </div>
          <a class="text-link" href={item.source.url} rel="noreferrer" target="_blank">{item.source.label}</a>
        </article>
      ))}
    </div>
  </section>
</Layout>

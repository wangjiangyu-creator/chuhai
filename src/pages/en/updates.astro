---
import Layout from '../../components/Layout.astro';
import SourceBadge from '../../components/SourceBadge.astro';
import updates from '../../data/updates.json';
import risks from '../../data/risks.json';
import { formatDate, riskLabel, text } from '../../lib/i18n';

const lang = 'en';
---

<Layout title="Developments | Chuhai Risk" description="Timeline of legal, enforcement, and case developments affecting Chinese companies overseas." lang={lang} route="updates">
  <section class="page-head">
    <SourceBadge lang={lang} />
    <h1>Recent Developments</h1>
    <p>This timeline focuses on rule and enforcement changes that alter corporate preparation windows. The static site does not auto-scrape news; updates are maintained through data files.</p>
  </section>
  <section class="section">
    <div class="timeline">
      {updates.map((item) => (
        <article class="timeline-item">
          <div class="timeline-meta">
            <span>{formatDate(item.date, lang)}</span>
            <span>{item.jurisdiction}</span>
            {item.effectiveDate && <span>Effective/applicable: {formatDate(item.effectiveDate, lang)}</span>}
          </div>
          <h2>{text(item.title, lang)}</h2>
          <p>{text(item.summary, lang)}</p>
          <div class="tag-list">
            {item.riskTypes.map((risk) => <span>{riskLabel(risk, lang, risks)}</span>)}
          </div>
          <a class="text-link" href={item.source.url} rel="noreferrer" target="_blank">{item.source.label}</a>
        </article>
      ))}
    </div>
  </section>
</Layout>

---
import authorities from '../data/authorities.json';
import risks from '../data/risks.json';
import { riskLabel, text, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const ui = {
  zh: {
    heading: '权威资料库',
    intro: '按官方、监管、法院/执法和国际组织来源整理，用于快速定位企业出海合规所需的原始材料。',
    search: '搜索标题、机构、法域或风险',
    jurisdiction: '法域',
    region: '区域',
    sourceType: '来源类型',
    all: '全部',
    count: '项资料',
    open: '打开来源',
    noResults: '没有匹配资料'
  },
  en: {
    heading: 'Authority Library',
    intro: 'Official, regulator, enforcement, and international organization materials for overseas compliance research.',
    search: 'Search title, organization, jurisdiction, or risk',
    jurisdiction: 'Jurisdiction',
    region: 'Region',
    sourceType: 'Source type',
    all: 'All',
    count: 'materials',
    open: 'Open source',
    noResults: 'No matching materials'
  }
}[lang];

const sorted = [...authorities].sort((a, b) => a.region.localeCompare(b.region) || a.jurisdiction.localeCompare(b.jurisdiction) || text(a.title, lang).localeCompare(text(b.title, lang)));
const jurisdictions = [...new Set(sorted.map((item) => item.jurisdiction))].sort();
const regions = [...new Set(sorted.map((item) => item.region))].sort();
const sourceTypes = [...new Set(sorted.map((item) => item.sourceType))].sort();
---

<section class="section authority-explorer" data-authority-explorer>
  <div class="section-header">
    <h2>{ui.heading}</h2>
    <p>{ui.intro}</p>
  </div>
  <div class="toolbar authority-toolbar" aria-label={ui.heading}>
    <label>
      <span>{ui.search}</span>
      <input type="search" data-search placeholder={ui.search} />
    </label>
    <label>
      <span>{ui.jurisdiction}</span>
      <select data-filter="jurisdiction">
        <option value="">{ui.all}</option>
        {jurisdictions.map((value) => <option value={value}>{value}</option>)}
      </select>
    </label>
    <label>
      <span>{ui.region}</span>
      <select data-filter="region">
        <option value="">{ui.all}</option>
        {regions.map((value) => <option value={value}>{value}</option>)}
      </select>
    </label>
    <label>
      <span>{ui.sourceType}</span>
      <select data-filter="sourceType">
        <option value="">{ui.all}</option>
        {sourceTypes.map((value) => <option value={value}>{value}</option>)}
      </select>
    </label>
  </div>
  <p class="result-count"><span data-count>{sorted.length}</span> {ui.count}</p>
  <div class="resource-grid">
    {sorted.map((item) => {
      const riskText = item.riskTypes.map((risk) => riskLabel(risk, lang, risks)).join(' ');
      const searchable = [
        item.id,
        item.jurisdiction,
        item.region,
        item.organization,
        item.sourceType,
        text(item.title, lang),
        text(item.summary, lang),
        riskText,
        ...item.riskTypes
      ].join(' ').toLowerCase();
      return (
        <article
          class="resource-card"
          data-card
          data-jurisdiction={item.jurisdiction}
          data-region={item.region}
          data-source-type={item.sourceType}
          data-text={searchable}
        >
          <div class="resource-meta">
            <span>{item.region}</span>
            <span>{item.jurisdiction}</span>
            <span>{item.sourceType}</span>
          </div>
          <h2>{text(item.title, lang)}</h2>
          <dl class="resource-details">
            <div>
              <dt>{lang === 'zh' ? '机构' : 'Organization'}</dt>
              <dd>{item.organization}</dd>
            </div>
          </dl>
          <p>{text(item.summary, lang)}</p>
          <div class="tag-list">
            {item.riskTypes.map((risk) => <span>{riskLabel(risk, lang, risks)}</span>)}
          </div>
          <a class="text-link" href={item.url} rel="noreferrer" target="_blank">{ui.open}</a>
        </article>
      );
    })}
  </div>
  <p class="empty-state" data-empty hidden>{ui.noResults}</p>
</section>

<script>
  const explorer = document.querySelector('[data-authority-explorer]');
  if (explorer) {
    const search = explorer.querySelector<HTMLInputElement>('[data-search]');
    const filters = [...explorer.querySelectorAll<HTMLSelectElement>('[data-filter]')];
    const cards = [...explorer.querySelectorAll<HTMLElement>('[data-card]')];
    const count = explorer.querySelector<HTMLElement>('[data-count]');
    const empty = explorer.querySelector<HTMLElement>('[data-empty]');
    const applyFilters = () => {
      if (!search || !count || !empty) return;
      const term = search.value.trim().toLowerCase();
      const selected = Object.fromEntries(filters.map((filter) => [filter.dataset.filter ?? '', filter.value]));
      let visible = 0;
      for (const card of cards) {
        const matchesSearch = !term || (card.dataset.text ?? '').includes(term);
        const matchesJurisdiction = !selected.jurisdiction || card.dataset.jurisdiction === selected.jurisdiction;
        const matchesRegion = !selected.region || card.dataset.region === selected.region;
        const matchesSourceType = !selected.sourceType || card.dataset.sourceType === selected.sourceType;
        const isVisible = matchesSearch && matchesJurisdiction && matchesRegion && matchesSourceType;
        card.hidden = !isVisible;
        if (isVisible) visible += 1;
      }
      count.textContent = String(visible);
      empty.hidden = visible !== 0;
    };
    search?.addEventListener('input', applyFilters);
    for (const filter of filters) filter.addEventListener('change', applyFilters);
  }
</script>
